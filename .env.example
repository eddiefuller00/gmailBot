OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_TEMPERATURE=0
OPENAI_CHAT_TOP_P=1
OPENAI_CHAT_MAX_TOKENS=500
OPENAI_CHAT_FREQUENCY_PENALTY=0
OPENAI_CHAT_PRESENCE_PENALTY=0
OPENAI_CHAT_SEED=
OPENAI_CHAT_STOP_SEQUENCES=
DATABASE_PATH=data/inbox_intelligence.db
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
FRONTEND_APP_URL=http://127.0.0.1:5173
# Dashboard auto-sync interval in milliseconds (minimum 60000, default 300000)
VITE_GMAIL_AUTO_SYNC_INTERVAL_MS=300000

# Google OAuth + Gmail
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/userinfo.profile

# Token storage security (recommended)
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
ALLOW_INSECURE_TOKEN_STORAGE=false
